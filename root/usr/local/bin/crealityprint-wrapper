#!/bin/bash

# Creality Print Wrapper with Intel iGPU stability improvements
# This wrapper manages memory and prevents hangs during settings changes

# Source Intel GPU environment
if [ -f /etc/profile.d/intel-gpu.sh ]; then
    source /etc/profile.d/intel-gpu.sh
fi

# Ensure persistent storage for Creality Print settings
# Fix any broken/self-referential symlinks in /config first
for path in /config/.config/CrealityPrint /config/.local/share/CrealityPrint /config/.config/Creality; do
    if [ -L "$path" ]; then
        echo "Removing broken symlink: $path"
        rm -f "$path"
    fi
done

# Create real directories in /config for persistent storage
mkdir -p /config/.config/CrealityPrint
mkdir -p /config/.local/share/CrealityPrint
mkdir -p /config/.config/Creality
mkdir -p /config/.cache
mkdir -p /config/.local/share/CrealityPrint/resources

# Only create symlinks if HOME is NOT /config (avoid self-referential symlinks)
if [ "$HOME" != "/config" ]; then
    mkdir -p "$HOME/.config"
    mkdir -p "$HOME/.local/share"

    # Remove any existing files/dirs and create symlinks
    rm -rf "$HOME/.config/CrealityPrint" 2>/dev/null
    ln -sf /config/.config/CrealityPrint "$HOME/.config/CrealityPrint"

    rm -rf "$HOME/.local/share/CrealityPrint" 2>/dev/null
    ln -sf /config/.local/share/CrealityPrint "$HOME/.local/share/CrealityPrint"

    rm -rf "$HOME/.config/Creality" 2>/dev/null
    ln -sf /config/.config/Creality "$HOME/.config/Creality"
fi

# Set XDG directories to ensure apps use /config
export XDG_CONFIG_HOME=/config/.config
export XDG_DATA_HOME=/config/.local/share
export XDG_CACHE_HOME=/config/.cache

# Log GPU status
echo "Starting Creality Print with Intel iGPU optimizations..."
echo "DRI_NODE: ${DRI_NODE:-not set}"
echo "DRINODE: ${DRINODE:-not set}"
echo "MESA_LOADER_DRIVER_OVERRIDE: ${MESA_LOADER_DRIVER_OVERRIDE:-not set}"

# Determine installation directory
INSTALL_DIR="${CREALITY_INSTALL_DIR:-/opt/crealityprint}"

# Persist parameter/resource updates: symlink resources to /config so
# filament profile updates survive container restarts
if [ -d "$INSTALL_DIR/resources" ] && [ ! -L "$INSTALL_DIR/resources" ]; then
    # First run: copy bundled resources to persistent storage, then symlink
    cp -rn "$INSTALL_DIR/resources/"* /config/.local/share/CrealityPrint/resources/ 2>/dev/null || true
    rm -rf "$INSTALL_DIR/resources"
    ln -sf /config/.local/share/CrealityPrint/resources "$INSTALL_DIR/resources"
elif [ ! -e "$INSTALL_DIR/resources" ]; then
    # Resources dir missing (e.g. after auto-update): recreate symlink
    ln -sf /config/.local/share/CrealityPrint/resources "$INSTALL_DIR/resources"
fi

# Ensure Creality Print can write to its installation directory
chown -R abc:abc "$INSTALL_DIR" 2>/dev/null || true

# Ensure D-Bus session bus is available for Creality Print IPC
export DBUS_SYSTEM_BUS_ADDRESS=unix:path=/run/dbus/system_bus_socket

# Disable WebKit2GTK bubblewrap sandbox (cannot run inside Docker without
# CAP_SYS_ADMIN / user namespaces — causes embedded web views to hang)
export WEBKIT_DISABLE_SANDBOX_THIS_IS_DANGEROUS=1
export WEBKIT_DISABLE_COMPOSITING_MODE=1

# Disable QtWebEngine Chromium sandbox (same container limitation)
export QTWEBENGINE_DISABLE_SANDBOX=1
export QTWEBENGINE_CHROMIUM_FLAGS="--no-sandbox --disable-gpu-sandbox"

# Launch Creality Print with optimized settings
cd "$INSTALL_DIR"

# Set additional runtime optimizations
export QT_QPA_PLATFORM=xcb
export QT_SCALE_FACTOR=1
export GDK_BACKEND=x11

# Disable GPU-intensive features that cause hangs
export __GL_SYNC_TO_VBLANK=0
export __GL_YIELD="USLEEP"

# Run Creality Print
exec "$INSTALL_DIR/AppRun" "$@"
